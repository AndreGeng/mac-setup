{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "command": {
    "format": {
      "description": "Format shell scripts, lua, python, and web files",
      "template": "Format all code files using appropriate formatters"
    },
    "test": {
      "description": "Test shell scripts and configuration",
      "template": "Run tests and validate setup"
    },
    "task": {
      "description": "把任务交给 workmux coordinator 执行，并在完成后合并代码",
      "template": "使用 coordinator skill，通过 workmux 端到端编排这个任务。任务：$ARGUMENTS\n\n要求：\n- 不要在当前 checkout 里直接实现。\n- 将请求拆成一个或多个 worktree agent 任务。\n- 使用 workmux 在后台启动 agents。\n- 等待 agents 完成。\n- 使用 workmux capture 审查它们的输出。\n- 对可接受的结果，逐个向对应 agent 发送 /merge 来合并分支。\n- 汇报已合并的分支、提交，以及任何被阻塞的 agent。"
    },
    "t": {
      "description": "/task 的快捷命令",
      "template": "使用 coordinator skill，通过 workmux 端到端编排这个任务。任务：$ARGUMENTS\n\n要求：\n- 不要在当前 checkout 里直接实现。\n- 将请求拆成一个或多个 worktree agent 任务。\n- 使用 workmux 在后台启动 agents。\n- 等待 agents 完成。\n- 使用 workmux capture 审查它们的输出。\n- 对可接受的结果，逐个向对应 agent 发送 /merge 来合并分支。\n- 汇报已合并的分支、提交，以及任何被阻塞的 agent。"
    }
  },
  "formatter": {
    "black": {
      "command": ["black", "$FILE"],
      "extensions": [".py"]
    },
    "isort": {
      "command": ["isort", "$FILE"],
      "extensions": [".py"]
    },
    "prettier": {
      "command": ["prettier", "--write", "$FILE"],
      "extensions": [
        ".js",
        ".ts",
        ".jsx",
        ".tsx",
        ".json",
        ".yaml",
        ".yml",
        ".md"
      ]
    },
    "shfmt": {
      "command": ["shfmt", "-w", "-i", "2", "$FILE"],
      "extensions": [".sh", ".bash"]
    },
    "stylua": {
      "command": [
        "stylua",
        "--config-path",
        "config/nvim/stylua.toml",
        "$FILE"
      ],
      "extensions": [".lua"]
    }
  },
  "instructions": ["AGENTS.md"],
  "mcp": {
    "chrome-devtools": {
      "command": ["npx", "-y", "chrome-devtools-mcp@latest"],
      "type": "local"
    },
    "feishu-mcp": {
      "type": "remote",
      "url": "https://open.feishu.cn/mcp/stream/mcp__aQA3IxPLp5MwCLVlNU76kVAeMEhKxl4MwJOOIVhIGh0cRWNWke1K_Ah1nRKocC12Zg8qfMxks8"
    },
    "gitnexus": {
      "command": ["gitnexus", "mcp"],
      "type": "local"
    },
    "playwright": {
      "command": ["npx", "-y", "@playwright/mcp@latest"],
      "type": "local"
    }
  },
  "model": "Mify-OpenAI/ppio/pa/gpt-5.5",
  "plugin": ["ecc-universal"],
  "provider": {
    "Mify-Anthropic": {
      "models": {
        "ppio/pa/claude-haiku-4-5-20251001": {
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          },
          "name": "ppio/pa/claude-haiku-4-5-20251001"
        },
        "ppio/pa/claude-opus-4-8": {
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          },
          "name": "ppio/pa/claude-opus-4-8"
        },
        "ppio/pa/claude-sonnet-4-6": {
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          },
          "name": "ppio/pa/claude-sonnet-4-6"
        }
      },
      "name": "Mify-Anthropic",
      "npm": "@ai-sdk/anthropic",
      "options": {
        "apiKey": "{env:MIFY_API_TEAM_KEY}",
        "baseURL": "{env:MIFY_API_ANTHROPIC_URL}"
      }
    },
    "Mify-Google": {
      "models": {
        "vertex_ai/gemini-3.5-flash": {
          "limit": {
            "context": 1000000,
            "output": 128000
          },
          "name": "gemini-3.5-flash"
        }
      },
      "name": "Mify-Google",
      "npm": "@ai-sdk/google",
      "options": {
        "apiKey": "{env:MIFY_API_TEAM_KEY}",
        "baseURL": "{env:MIFY_API_SGP_URL}"
      }
    },
    "Mify-Kimi": {
      "models": {
        "moonshot/kimi-k2.6": {
          "name": "moonshot/kimi-k2.6"
        }
      },
      "name": "Mify-Kimi",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "apiKey": "{env:MIFY_API_TEAM_KEY}",
        "baseURL": "{env:MIFY_API_URL}"
      }
    },
    "Mify-OpenAI": {
      "models": {
        "ppio/pa/gpt-5.5": {
          "limit": {
            "context": 272000,
            "output": 128000
          },
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          },
          "name": "GPT 5.5",
          "variants": {
            "high": {
              "reasoningEffort": "high",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "low": {
              "reasoningEffort": "low",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "medium": {
              "reasoningEffort": "medium",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "xhigh": {
              "reasoningEffort": "xhigh",
              "reasoningSummary": "detailed",
              "textVerbosity": "medium"
            }
          }
        }
      },
      "name": "Mify-OpenAI",
      "npm": "@ai-sdk/openai",
      "options": {
        "apiKey": "{env:MIFY_API_TEAM_KEY}",
        "baseURL": "{env:MIFY_API_URL}"
      }
    },
    "Mify-Xiaomi": {
      "models": {
        "xiaomi/mimo-v2.5": {
          "interleaved": {
            "field": "reasoning_content"
          },
          "limit": {
            "context": 1048576,
            "output": 65536
          },
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          },
          "name": "xiaomi/mimo-v2.5",
          "options": {
            "thinking": {
              "type": "enabled"
            }
          }
        },
        "xiaomi/mimo-v2.5-pro": {
          "interleaved": {
            "field": "reasoning_content"
          },
          "limit": {
            "context": 1048576,
            "output": 65536
          },
          "name": "xiaomi/mimo-v2.5-pro",
          "options": {
            "thinking": {
              "type": "enabled"
            }
          }
        }
      },
      "name": "Mify-Xiaomi",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "apiKey": "{env:MIFY_API_TEAM_KEY}",
        "baseURL": "{env:MIFY_API_URL}"
      }
    },
    "Mify-Zhipu": {
      "models": {
        "zhipuai/glm-5.2": {
          "name": "zhipuai/glm-5.2"
        }
      },
      "name": "Mify-Zhipu",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "apiKey": "{env:MIFY_API_TEAM_KEY}",
        "baseURL": "{env:MIFY_API_URL}"
      }
    }
  },
  "theme": "dark",
  "watcher": {
    "ignore": ["node_modules/**", "dist/**", ".git/**", "*.tmp"]
  }
}
